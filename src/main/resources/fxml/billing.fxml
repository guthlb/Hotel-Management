<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:controller="com.hotel.controller.BillingController" prefHeight="720.0" prefWidth="1200.0" styleClass="dashboard-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <left>
        <VBox prefWidth="250.0" spacing="18.0" styleClass="sidebar">
            <padding>
                <Insets bottom="24.0" left="20.0" right="20.0" top="24.0" />
            </padding>
            <Label styleClass="sidebar-title" text="Hotel Manager" />
            <Label styleClass="sidebar-subtitle" text="Desktop Management System" />
            <VBox spacing="10.0">
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#openDashboard" prefHeight="42.0" styleClass="sidebar-button" text="Dashboard" />
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#openRooms" prefHeight="42.0" styleClass="sidebar-button" text="Rooms" />
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#openCustomers" prefHeight="42.0" styleClass="sidebar-button" text="Customers" />
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#openBookings" prefHeight="42.0" styleClass="sidebar-button" text="Bookings" />
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#openBilling" prefHeight="42.0" styleClass="sidebar-button-active" text="Billing" />
            </VBox>
            <Region VBox.vgrow="ALWAYS" />
        </VBox>
    </left>

    <center>
        <VBox spacing="20.0" styleClass="content-area">
            <padding>
                <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
            </padding>

            <VBox spacing="4.0">
                <Label styleClass="page-title" text="Billing System" />
                <Label styleClass="page-subtitle" text="Calculate room bill using room price, number of days, and service charge." />
            </VBox>

            <VBox spacing="18.0" styleClass="card-panel">
                <Label styleClass="section-title" text="Bill Calculator" />

                <GridPane hgap="16.0" vgap="16.0">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="20.0" />
                        <ColumnConstraints percentWidth="30.0" />
                        <ColumnConstraints percentWidth="20.0" />
                        <ColumnConstraints percentWidth="30.0" />
                    </columnConstraints>

                    <Label text="Room" />
                    <ComboBox fx:id="roomComboBox" prefWidth="220.0" GridPane.columnIndex="1" />

                    <Label text="Start Date" GridPane.columnIndex="2" />
                    <DatePicker fx:id="startDatePicker" onAction="#handleDateSelection" GridPane.columnIndex="3" />

                    <Label text="End Date" GridPane.rowIndex="1" />
                    <DatePicker fx:id="endDatePicker" onAction="#handleDateSelection" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                    <Label text="Number of Days" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                    <Label fx:id="daysLabel" styleClass="summary-label" text="0" GridPane.columnIndex="3" GridPane.rowIndex="1" />

                    <Label text="Service Charge" GridPane.rowIndex="2" />
                    <TextField fx:id="serviceChargeField" promptText="Enter service charge" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                </GridPane>

                <HBox alignment="CENTER_RIGHT">
                    <Region HBox.hgrow="ALWAYS" />
                    <Button mnemonicParsing="false" onAction="#calculateBill" prefHeight="40.0" prefWidth="150.0" styleClass="action-button" text="Calculate Bill" />
                </HBox>
            </VBox>

            <VBox spacing="12.0" styleClass="card-panel">
                <Label styleClass="section-title" text="Billing Result" />
                <Label fx:id="selectedRoomLabel" styleClass="page-subtitle" text="Selected room: -" />
                <Label fx:id="totalBillLabel" styleClass="page-title" text="Total Bill: Rs. 0.00" />
            </VBox>
        </VBox>
    </center>
</BorderPane>
