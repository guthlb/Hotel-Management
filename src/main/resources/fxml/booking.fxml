<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:controller="com.hotel.controller.BookingController" prefHeight="720.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <left>
        <VBox prefWidth="250.0" spacing="18.0" style="-fx-background-color: #12343b;">
            <padding>
                <Insets bottom="24.0" left="20.0" right="20.0" top="24.0" />
            </padding>
            <Label style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" text="Hotel Manager" />
            <Label style="-fx-text-fill: #cce3e8; -fx-font-size: 13px;" text="Desktop Management System" />
            <VBox spacing="10.0">
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#openDashboard" prefHeight="42.0" style="-fx-background-color: #1a4952; -fx-text-fill: white;" text="Dashboard" />
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#openRooms" prefHeight="42.0" style="-fx-background-color: #1a4952; -fx-text-fill: white;" text="Rooms" />
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#openCustomers" prefHeight="42.0" style="-fx-background-color: #1a4952; -fx-text-fill: white;" text="Customers" />
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#openBookings" prefHeight="42.0" style="-fx-background-color: #d4f0f5; -fx-text-fill: #12343b; -fx-font-weight: bold;" text="Bookings" />
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#openBilling" prefHeight="42.0" style="-fx-background-color: #1a4952; -fx-text-fill: white;" text="Billing" />
            </VBox>
            <Region VBox.vgrow="ALWAYS" />
        </VBox>
    </left>

    <center>
        <VBox spacing="20.0" style="-fx-background-color: #f5f8fa;">
            <padding>
                <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
            </padding>

            <VBox spacing="4.0">
                <Label style="-fx-text-fill: #12343b; -fx-font-size: 28px; -fx-font-weight: bold;" text="Booking Management" />
                <Label style="-fx-text-fill: #53757d; -fx-font-size: 14px;" text="Assign rooms to customers and checkout active bookings." />
            </VBox>

            <VBox spacing="18.0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #d9e4e8; -fx-border-radius: 14; -fx-padding: 20;">
                <Label style="-fx-text-fill: #12343b; -fx-font-size: 20px; -fx-font-weight: bold;" text="Create Booking" />

                <GridPane hgap="16.0" vgap="16.0">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="20.0" />
                        <ColumnConstraints percentWidth="30.0" />
                        <ColumnConstraints percentWidth="20.0" />
                        <ColumnConstraints percentWidth="30.0" />
                    </columnConstraints>

                    <Label text="Select Customer" />
                    <ComboBox fx:id="customerComboBox" prefWidth="220.0" GridPane.columnIndex="1" />

                    <Label text="Select Room" GridPane.columnIndex="2" />
                    <ComboBox fx:id="roomComboBox" prefWidth="220.0" GridPane.columnIndex="3" />
                </GridPane>

                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                    <Region HBox.hgrow="ALWAYS" />
                    <Button mnemonicParsing="false" onAction="#handleCreateBooking" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: #12343b; -fx-text-fill: white; -fx-font-weight: bold;" text="Create Booking" />
                    <Button mnemonicParsing="false" onAction="#handleCheckout" prefHeight="40.0" prefWidth="130.0" style="-fx-background-color: #9a5d00; -fx-text-fill: white; -fx-font-weight: bold;" text="Checkout" />
                </HBox>
            </VBox>

            <VBox spacing="14.0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #d9e4e8; -fx-border-radius: 14; -fx-padding: 20;" VBox.vgrow="ALWAYS">
                <Label style="-fx-text-fill: #12343b; -fx-font-size: 20px; -fx-font-weight: bold;" text="Booking List" />
                <TableView fx:id="bookingTableView" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="bookingIdColumn" prefWidth="110.0" text="Booking ID" />
                        <TableColumn fx:id="customerNameColumn" prefWidth="220.0" text="Customer" />
                        <TableColumn fx:id="roomNumberColumn" prefWidth="180.0" text="Room" />
                        <TableColumn fx:id="statusColumn" prefWidth="180.0" text="Status" />
                    </columns>
                </TableView>
            </VBox>
        </VBox>
    </center>
</BorderPane>
