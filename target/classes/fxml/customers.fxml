<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:controller="com.hotel.controller.PlaceholderController" prefHeight="720.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <left>
        <VBox prefWidth="250.0" spacing="18.0" style="-fx-background-color: #12343b;">
            <padding>
                <Insets bottom="24.0" left="20.0" right="20.0" top="24.0" />
            </padding>
            <Label style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" text="Hotel Manager" />
            <VBox spacing="10.0">
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#openDashboard" prefHeight="42.0" style="-fx-background-color: #1a4952; -fx-text-fill: white;" text="Dashboard" />
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#openRooms" prefHeight="42.0" style="-fx-background-color: #1a4952; -fx-text-fill: white;" text="Rooms" />
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#openCustomers" prefHeight="42.0" style="-fx-background-color: #d4f0f5; -fx-text-fill: #12343b; -fx-font-weight: bold;" text="Customers" />
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#openBookings" prefHeight="42.0" style="-fx-background-color: #1a4952; -fx-text-fill: white;" text="Bookings" />
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#openBilling" prefHeight="42.0" style="-fx-background-color: #1a4952; -fx-text-fill: white;" text="Billing" />
            </VBox>
            <Region VBox.vgrow="ALWAYS" />
        </VBox>
    </left>
    <center>
        <VBox alignment="CENTER" spacing="16.0" style="-fx-background-color: #f5f8fa;">
            <padding>
                <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
            </padding>
            <Label style="-fx-text-fill: #12343b; -fx-font-size: 30px; -fx-font-weight: bold;" text="Customer Management" />
            <Label style="-fx-text-fill: #53757d; -fx-font-size: 16px;" text="This is a simple placeholder screen for the Customers page." />
        </VBox>
    </center>
</BorderPane>
