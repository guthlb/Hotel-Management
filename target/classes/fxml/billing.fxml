<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:controller="com.hotel.controller.BillingController" prefHeight="720.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <left>
        <VBox prefWidth="250.0" spacing="18.0" style="-fx-background-color: #12343b;">
            <padding>
                <Insets bottom="24.0" left="20.0" right="20.0" top="24.0" />
            </padding>
            <Label style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" text="Hotel Manager" />
            <Label style="-fx-text-fill: #cce3e8; -fx-font-size: 13px;" text="Desktop Management System" />
            <VBox spacing="10.0">
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#openDashboard" prefHeight="42.0" style="-fx-background-color: #1a4952; -fx-text-fill: white;" text="Dashboard" />
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#openRooms" prefHeight="42.0" style="-fx-background-color: #1a4952; -fx-text-fill: white;" text="Rooms" />
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#openCustomers" prefHeight="42.0" style="-fx-background-color: #1a4952; -fx-text-fill: white;" text="Customers" />
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#openBookings" prefHeight="42.0" style="-fx-background-color: #1a4952; -fx-text-fill: white;" text="Bookings" />
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#openBilling" prefHeight="42.0" style="-fx-background-color: #d4f0f5; -fx-text-fill: #12343b; -fx-font-weight: bold;" text="Billing" />
            </VBox>
            <Region VBox.vgrow="ALWAYS" />
        </VBox>
    </left>

    <center>
        <VBox spacing="20.0" style="-fx-background-color: #f5f8fa;">
            <padding>
                <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
            </padding>

            <VBox spacing="4.0">
                <Label style="-fx-text-fill: #12343b; -fx-font-size: 28px; -fx-font-weight: bold;" text="Billing System" />
                <Label style="-fx-text-fill: #53757d; -fx-font-size: 14px;" text="Calculate room bill using room price, number of days, and service charge." />
            </VBox>

            <VBox spacing="18.0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #d9e4e8; -fx-border-radius: 14; -fx-padding: 20;">
                <Label style="-fx-text-fill: #12343b; -fx-font-size: 20px; -fx-font-weight: bold;" text="Bill Calculator" />

                <GridPane hgap="16.0" vgap="16.0">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="20.0" />
                        <ColumnConstraints percentWidth="30.0" />
                        <ColumnConstraints percentWidth="20.0" />
                        <ColumnConstraints percentWidth="30.0" />
                    </columnConstraints>

                    <Label text="Room" />
                    <ComboBox fx:id="roomComboBox" prefWidth="220.0" GridPane.columnIndex="1" />

                    <Label text="Number of Days" GridPane.columnIndex="2" />
                    <TextField fx:id="daysField" promptText="Enter days" GridPane.columnIndex="3" />

                    <Label text="Service Charge" GridPane.rowIndex="1" />
                    <TextField fx:id="serviceChargeField" promptText="Enter service charge" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                </GridPane>

                <HBox alignment="CENTER_RIGHT">
                    <Region HBox.hgrow="ALWAYS" />
                    <Button mnemonicParsing="false" onAction="#calculateBill" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: #12343b; -fx-text-fill: white; -fx-font-weight: bold;" text="Calculate Bill" />
                </HBox>
            </VBox>

            <VBox spacing="12.0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #d9e4e8; -fx-border-radius: 14; -fx-padding: 20;">
                <Label style="-fx-text-fill: #12343b; -fx-font-size: 20px; -fx-font-weight: bold;" text="Billing Result" />
                <Label fx:id="selectedRoomLabel" style="-fx-text-fill: #53757d; -fx-font-size: 15px;" text="Selected room: -" />
                <Label fx:id="totalBillLabel" style="-fx-text-fill: #12343b; -fx-font-size: 24px; -fx-font-weight: bold;" text="Total Bill: Rs. 0.00" />
            </VBox>
        </VBox>
    </center>
</BorderPane>
